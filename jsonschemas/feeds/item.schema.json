{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "item.schema.json",
  "type": "object",
  "description": "Envelope for a single JSONL line in a feeds import file. The 'type' field discriminates the payload in 'data'.",
  "additionalProperties": false,
  "required": ["type", "data"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "user",
        "feed",
        "feed_group",
        "feed_view",
        "activity",
        "comment",
        "reaction",
        "bookmark",
        "follow",
        "collection"
      ]
    },
    "data": {
      "anyOf": [
        { "$ref": "user.schema.json" },
        { "$ref": "feed.schema.json" },
        { "$ref": "feed_group.schema.json" },
        { "$ref": "feed_view.schema.json" },
        { "$ref": "activity.schema.json" },
        { "$ref": "comment.schema.json" },
        { "$ref": "reaction.schema.json" },
        { "$ref": "bookmark.schema.json" },
        { "$ref": "follow.schema.json" },
        { "$ref": "collection.schema.json" }
      ]
    }
  }
}
