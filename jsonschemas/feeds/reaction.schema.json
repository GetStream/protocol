{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reaction.schema.json",
  "type": "object",
  "description": "Feeds reaction entity for import.",
  "required": ["user_id", "activity_id", "type"],
  "properties": {
    "user_id": { "type": "string", "minLength": 1 },
    "activity_id": {
      "type": "string",
      "minLength": 1,
      "description": "Activity this reaction targets. Required even when 'comment_id' is set."
    },
    "comment_id": {
      "type": "string",
      "description": "Set when reacting to a comment on the activity."
    },
    "type": {
      "type": "string",
      "minLength": 1,
      "description": "Reaction type, e.g. 'like', 'upvote'."
    },
    "custom": { "type": "object", "additionalProperties": true },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
